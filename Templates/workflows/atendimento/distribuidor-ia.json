        {
            "parameters": {
                "jsCode": "// Pega os dados da variável do Aggregate\nconst basedados = $item(0).$node[\"Aggregate\"].json[\"basedados\"]\n\n// Garante que é um array e pega o primeiro item\nconst item = Array.isArray(basedados) ? basedados[0] : basedados\n\n// Pega o conteúdo da chave \"query\"\nconst query = item.query\n\nlet telefone\n\n// 1️⃣ Extrai tudo que estiver entre aspas dentro da query\nconst valores = query.match(/\"([^\"]*)\"/g)?.map(v => v.replace(/\"/g, \"\")) || []\n\n// 2️⃣ Verifica se algum valor parece ser telefone (variações de campo ou @s.whatsapp.net)\nfor (const valor of valores) {\n  // Caso tenha formato WhatsApp\n  if (valor.includes(\"@s.whatsapp.net\")) {\n    telefone = valor\n    break\n  }\n\n  // Caso tenha apenas números (mínimo 10 dígitos)\n  const limpo = valor.replace(/\\D/g, \"\")\n  if (limpo.length >= 10 && limpo.length <= 13) {\n    telefone = limpo\n    break\n  }\n}\n\n// 3️⃣ Se ainda não encontrou, tenta extrair número bruto da string toda\nif (!telefone) {\n  const match = query.match(/\\d{10,13}/)\n  if (match) telefone = match[0]\n}\n\n// 4️⃣ Limpa o telefone (remove domínio se existir)\nif (telefone && telefone.includes(\"@s.whatsapp.net\")) {\n  telefone = telefone.replace(\"@s.whatsapp.net\", \"\")\n}\n\n// Retorna o telefone encontrado\nreturn { telefone }\n"
            },
