                            "message": "={\n  \"parser_instructions\": {\n    \"description\": \"Parser V3 - Divisão conversacional para WhatsApp com agrupamento\",\n    \"version\": \"3.0\",\n    \"output_format\": {\n      \"messages\": [\n        \"mensagem_1\",\n        \"mensagem_2\",\n        \"mensagem_N\"\n      ]\n    },\n    \"strategy\": \"Agrupar 2-3 frases coesas por mensagem (visando 150-300 chars) para evitar 'picotar' a conversa. NÃO quebrar saudações, explicações curtas ou perguntas de seus contextos imediatos. É melhor um balão de 250 chars do que 4 balões de 60.\",\n    \"rules\": [\n      {\n        \"rule_id\": 1,\n        \"category\": \"Output Format\",\n        \"instruction\": \"Sempre retorne JSON válido no formato: {\\\"messages\\\": [\\\"msg1\\\", \\\"msg2\\\", ...]}\",\n        \"validation\": \"Objeto JSON com chave 'messages' contendo array de strings não-vazias\"\n      },\n      {\n        \"rule_id\": 2,\n        \"category\": \"Character Limits (Conversational)\",\n        \"instruction\": \"Tentar agrupar 2-3 frases por mensagem, mantendo um limite razoável\",\n        \"limits\": {\n          \"minimum\": 60,\n          \"ideal\": 150,\n          \"maximum\": 300,\n          \"exceptions\": [\n            \"Scripts entre aspas/itálico podem ter até 350 chars\",\n            \"Mensagem original < 60 chars retorna sem divisão\",\n            \"Último fragmento pode ter < 60 chars se for resto natural\"\n          ]\n        },\n        \"rationale\": \"Mensagens curtas demais fragmentam a conversa. Agrupar frases (até 300 chars) parece mais humano e menos robótico.\"\n      },\n      {\n        \"rule_id\": 3,\n        \"category\": \"Splitting Priority (Order Matters!)\",\n        \"instruction\": \"Aplicar critérios de divisão nesta ordem de prioridade\",\n        \"priority_order\": [\n          {\n            \"priority\": 1,\n            \"criterion\": \"Parágrafos\",\n            \"pattern\": \"\\\\n\\\\n (linha em branco)\",\n            \"action\": \"SEMPRE dividir em mensagem separada\",\n            \"example\": \"'Texto parágrafo 1.\\\\n\\\\nTexto parágrafo 2.' → 2 mensagens\"\n          },\n          {\n            \"priority\": 2,\n            \"criterion\": \"Itens de lista\",\n            \"patterns\": [\n              \"Emojis de prioridade: 🔴 🟡 🟢\",\n              \"Emojis de lista: ✨ ⭐ 📌 ✅ ❌\",\n              \"Bullets tradicionais: - • ◦\",\n              \"Numeração: 1️⃣ 2️⃣ 3️⃣ ou 1. 2. 3.\"\n            ],\n            \"action\": \"CADA item de lista vira UMA mensagem separada\",\n            \"example\": \"'🔴 Item 1\\\\n🟡 Item 2\\\\n🟢 Item 3' → 3 mensagens\"\n          },\n          {\n            \"priority\": 3,\n            \"criterion\": \"Introdução de lista\",\n            \"patterns\": [\n              \"Texto terminando com ':' (dois pontos)\",\n              \"Frases tipo 'priorize:', 'sugiro:', 'veja:', 'são elas:'\"\n            ],\n            \"action\": \"Isolar introdução em mensagem própria, ANTES dos itens\",\n            \"example\": \"'Priorize:\\\\n🔴 Item 1' → Msg1='Priorize:' | Msg2='🔴 Item 1'\"\n          },\n          {\n            \"priority\": 4,\n            \"criterion\": \"Perguntas isoladas\",\n            \"patterns\": [\n              \"Frase terminando com '?'\",\n              \"Especialmente chamadas para ação: 'Quer os scripts?', 'É só falar!'\"\n            ],\n            \"action\": \"Separar pergunta/chamada em mensagem própria (se não for muito curta e fizer parte de uma saudação)\",\n            \"example\": \"'Vejo que você precisa disso. Quer ajuda?' → 2 mensagens\"\n          },\n          {\n            \"priority\": 5,\n            \"criterion\": \"Limite de caracteres (150-300)\",\n            \"action\": \"Se mensagem > 300 chars após aplicar regras acima, quebrar em frase completa (. ! ?)\",\n            \"fallback\": \"Se frase > 300 chars, quebrar após vírgula ou travessão mantendo sentido completo\"\n          },\n          {\n            \"priority\": 6,\n            \"criterion\": \"Scripts e templates\",\n            \"patterns\": [\n              \"Texto entre 'aspas simples' ou \\\"aspas duplas\\\"\",\n              \"Texto em _itálico_ (geralmente exemplos de mensagem)\"\n            ],\n            \"action\": \"NUNCA quebrar. Manter script completo mesmo se > 150 chars (até 350 chars)\",\n            \"exception\": \"Se script muito longo (>350), colocar em mensagem separada isolada\"\n          }\n        ]\n      },\n      {\n        \"rule_id\": 4,\n        \"category\": \"Formatting - WhatsApp\",\n        \"instruction\": \"Converter markdown para WhatsApp e preservar formatação\",\n        \"conversions\": {\n          \"bold\": \"**texto** → *texto*\",\n          \"strikethrough\": \"~~texto~~ → ~texto~\",\n          \"italic\": \"_texto_ → _texto_ (manter)\",\n          \"preserve_emojis\": \"Manter TODOS os emojis intactos\"\n        }\n      },\n      {\n        \"rule_id\": 5,\n        \"category\": \"Special Patterns\",\n        \"instruction\": \"Reconhecer e tratar padrões especiais do Commercial Agent\",\n        \"patterns\": {\n          \"priority_list\": {\n            \"description\": \"Lista de prioridades com 🔴🟡🟢\",\n            \"example_input\": \"Priorize:\\\\n🔴 URGENTE: 5 clientes\\\\n🟡 IMPORTANTE: Templates\\\\n🟢 MELHORIA: TMR\",\n            \"example_output\": {\n              \"messages\": [\n                \"Priorize:\",\n                \"🔴 URGENTE: 5 clientes há 48h+ sem resposta\",\n                \"🟡 IMPORTANTE: Criar templates de saudação\",\n                \"🟢 MELHORIA: Reduzir TMR no horário 19h-21h\"\n              ]\n            }\n          },\n          \"script_suggestion\": {\n            \"description\": \"Sugestão de script com contexto + exemplo\",\n            \"example_input\": \"Para follow-ups, sugiro:\\\\n'Oi [nome]! Retomando nossa conversa sobre [produto]. Conseguiu pensar melhor?'\\\\nPersonalize com contexto.\",\n            \"example_output\": {\n              \"messages\": [\n                \"Para follow-ups, sugiro:\",\n                \"'Oi [nome]! Retomando nossa conversa sobre [produto]. Conseguiu pensar melhor?'\",\n                \"Personalize com contexto de cada lead.\"\n              ]\n            }\n          },\n          \"metric_interpretation\": {\n            \"description\": \"Interpretação de métrica + benchmark + ação\",\n            \"example_input\": \"Seu TMR de 45 minutos está acima do ideal para vendas (benchmark: 15-30min). Leads esfriam rápido! Priorize mensagens novas primeiro.\",\n            \"example_output\": {\n              \"messages\": [\n                \"Seu TMR de 45 minutos está acima do ideal para vendas (benchmark: 15-30min). Leads esfriam rápido!\",\n                \"Priorize responder mensagens novas primeiro, depois follow-ups.\"\n              ]\n            }\n          },\n          \"do_dont_list\": {\n            \"description\": \"Listas com ✅ (DO) e ❌ (DON'T)\",\n            \"example_input\": \"✅ Use tom amigável\\\\n✅ Ofereça ajuda\\\\n❌ Criticar negativamente\\\\n❌ Promessas irreais\",\n            \"example_output\": {\n              \"messages\": [\n                \"✅ Use tom amigável\",\n                \"✅ Ofereça ajuda proativamente\",\n                \"❌ Criticar negativamente\",\n                \"❌ Fazer promessas irreais\"\n              ]\n            }\n          },\n          \"options_list\": {\n            \"description\": \"Opções de resposta (bandeiras, escolhas)\",\n            \"example_input\": \"Escolha sua região:\\\\n🇧🇷 Brasil (Português)\\\\n🇵🇹 Portugal (Português)\",\n            \"example_output\": {\n              \"messages\": [\n                \"Escolha sua região:\",\n                \"🇧🇷 Brasil (Português)\",\n                \"🇵🇹 Portugal (Português)\"\n              ]\n            }\n          }\n        }\n      },\n      {\n        \"rule_id\": 6,\n        \"category\": \"Context Preservation\",\n        \"instruction\": \"Ao dividir, garantir que cada parte faça sentido isolada\",\n        \"rules\": [\n          \"Se dividir lista longa (>5 itens), adicionar '(continuação)' na 6ª mensagem\",\n          \"Se quebrar frase no meio, começar próxima parte com contexto mínimo\",\n          \"Manter emojis de prioridade com seu texto correspondente na mesma mensagem\",\n          \"Nunca quebrar: números de telefone, URLs, nomes próprios entre colchetes [nome]\"\n        ]\n      },\n      {\n        \"rule_id\": 7,\n        \"category\": \"Edge Cases\",\n        \"instruction\": \"Tratamento de casos especiais\",\n        \"cases\": {\n          \"very_short\": \"Mensagem < 60 chars → retornar sem divisão\",\n          \"single_word\": \"Respostas curtas ('Oi!', 'Claro', 'Sim') → não dividir\",\n          \"very_long\": \"Mensagem > 1000 chars → pode gerar 10+ partes, sem limite\",\n          \"empty_input\": \"Input vazio/null → retornar {\\\"messages\\\": [\\\"(resposta vazia)\\\"]}\",\n          \"only_emojis\": \"Mensagem só com emojis (ex: '🔴🟡🟢') → não dividir\",\n          \"urls\": \"URLs devem permanecer inteiras na mesma mensagem\",\n          \"phone_numbers\": \"Telefones (+55..., (11) 9...) devem permanecer inteiros\"\n        }\n      },\n      {\n        \"rule_id\": 8,\n        \"category\": \"Validation\",\n        \"instruction\": \"Validações finais antes de retornar output\",\n        \"checks\": [\n          \"Cada mensagem tem trim().length > 0 (não vazia)\",\n          \"Nenhuma mensagem excede 350 chars (exceto scripts longos)\",\n          \"Formatação WhatsApp aplicada (** → *)\",\n          \"JSON válido e parseável\",\n          \"Array 'messages' tem pelo menos 1 elemento\"\n        ]\n      }\n    ],\n    \"workflow\": [\n      \"1. PARSE: Identificar estrutura (parágrafos, listas, scripts, perguntas)\",\n      \"2. SPLIT: Aplicar prioridades de divisão (parágrafos → itens lista → perguntas → limite chars)\",\n      \"3. ISOLATE: Separar introduções de lista e chamadas para ação\",\n      \"4. FORMAT: Converter ** → * (markdown para WhatsApp)\",\n      \"5. VALIDATE: Verificar tamanho (150-300 chars ideal) e contexto preservado\",\n      \"6. OUTPUT: Retornar JSON {\\\"messages\\\": [...]}\"\n    ],\n    \"examples\": [\n      {\n        \"scenario\": \"Resposta simples curta\",\n        \"input\": \"Oi! É só falar!\",\n        \"output\": {\n          \"messages\": [\n            \"Oi! É só falar!\"\n          ]\n        },\n        \"note\": \"< 60 chars, não divide\"\n      },\n      {\n        \"scenario\": \"Resposta com introdução + chamada\",\n        \"input\": \"Oi! Vejo que está me cumprimentando. Se quiser, posso ajudar com alguma dúvida sobre seu atendimento, métricas ou até sugerir mensagens para follow-up. É só falar!\",\n        \"output\": {\n          \"messages\": [\n            \"Oi! Vejo que está me cumprimentando. Se quiser, posso ajudar com alguma dúvida sobre seu atendimento, métricas ou até sugerir mensagens para follow-up.\",\n            \"É só falar!\"\n          ]\n        },\n        \"note\": \"Agrupado para evitar quebra de saudação/explicação. CTA isolado.\"\n      },\n      {\n        \"scenario\": \"Lista de prioridades\",\n        \"input\": \"Com base no relatório, priorize nesta ordem:\\n\\n🔴 URGENTE: 5 clientes há 48h+ sem resposta (risco alto de perda)\\n🟡 IMPORTANTE: Criar template de saudação (40% sem abertura)\\n🟢 MELHORIA: Reduzir TMR no horário 19h-21h (atualmente 2h)\\n\\nComençando pelos 5 clientes urgentes, você protege conversões imediatas. Quer os scripts?\",\n        \"output\": {\n          \"messages\": [\n            \"Com base no relatório, priorize nesta ordem:\",\n            \"🔴 URGENTE: 5 clientes há 48h+ sem resposta (risco alto de perda)\",\n            \"🟡 IMPORTANTE: Criar template de saudação (40% sem abertura)\",\n            \"🟢 MELHORIA: Reduzir TMR no horário 19h-21h (atualmente 2h)\",\n            \"Començando pelos 5 clientes urgentes, você protege conversões imediatas.\",\n            \"Quer os scripts?\"\n          ]\n        },\n        \"note\": \"Introdução isolada, cada item de lista = 1 mensagem, pergunta final isolada\"\n      },\n      {\n        \"scenario\": \"Script com contexto\",\n        \"input\": \"Para os 12 follow-ups pendentes, sugiro este modelo:\\n\\n'Oi [nome]! Retomando nossa conversa sobre [produto]. Conseguiu pensar melhor? Posso esclarecer alguma dúvida?'\\n\\nPersonalize com o contexto específico de cada lead. Envie primeiro para quem está há 48h+ sem resposta.\",\n        \"output\": {\n          \"messages\": [\n            \"Para os 12 follow-ups pendentes, sugiro este modelo:\",\n            \"'Oi [nome]! Retomando nossa conversa sobre [produto]. Conseguiu pensar melhor? Posso esclarecer alguma dúvida?'\",\n            \"Personalize com o contexto específico de cada lead. Envie primeiro para quem está há 48h+ sem resposta.\"\n          ]\n        },\n        \"note\": \"Script mantido intacto. Contexto antes/depois agrupado em 1 mensagem.\"\n      },\n      {\n        \"scenario\": \"Interpretação de métrica\",\n        \"input\": \"Seu TMR de 45 minutos está acima do ideal para vendas (benchmark: 15-30min). Leads esfriam rápido! Priorize responder mensagens novas primeiro, depois follow-ups. Quer um checklist de priorização?\",\n        \"output\": {\n          \"messages\": [\n            \"Seu TMR de 45 minutos está acima do ideal para vendas (benchmark: 15-30min). Leads esfriam rápido!\",\n            \"Priorize responder mensagens novas primeiro, depois follow-ups.\",\n            \"Quer um checklist de priorização?\"\n          ]\n        },\n        \"note\": \"Agrupado frases de contexto. Ação e Pergunta separadas.\"\n      },\n      {\n        \"scenario\": \"Análise com múltiplos pontos\",\n        \"input\": \"Vejo dois pontos críticos no relatório de hoje:\\n1️⃣ TMR de 45min (clientes esfriam)\\n2️⃣ 12 follow-ups perdidos (op