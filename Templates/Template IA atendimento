n            \"example_output\": {\n              \"messages\": [\n                \"Para follow-ups, sugiro:\",\n                \"'Oi [nome]! Retomando nossa conversa sobre [produto]. Conseguiu pensar melhor?'\",\n                \"Personalize com contexto de cada lead.\"\n              ]\n            }\n          },\n          \"metric_interpretation\": {\n            \"description\": \"Interpretação de métrica + benchmark + ação\",\n            \"example_input\": \"Seu TMR de 45 minutos está acima do ideal para vendas (benchmark: 15-30min). Leads esfriam rápido! Priorize mensagens novas primeiro.\",\n            \"example_output\": {\n              \"messages\": [\n                \"Seu TMR de 45 minutos está acima do ideal para vendas (benchmark: 15-30min). Leads esfriam rápido!\",\n                \"Priorize responder mensagens novas primeiro, depois follow-ups.\"\n              ]\n            }\n          },\n          \"do_dont_list\": {\n            \"description\": \"Listas com ✅ (DO) e ❌ (DON'T)\",\n            \"example_input\": \"✅ Use tom amigável\\\\n✅ Ofereça ajuda\\\\n❌ Criticar negativamente\\\\n❌ Promessas irreais\",\n            \"example_output\": {\n              \"messages\": [\n                \"✅ Use tom amigável\",\n                \"✅ Ofereça ajuda proativamente\",\n                \"❌ Criticar negativamente\",\n                \"❌ Fazer promessas irreais\"\n              ]\n            }\n          },\n          \"options_list\": {\n            \"description\": \"Opções de resposta (bandeiras, escolhas)\",\n            \"example_input\": \"Escolha sua região:\\\\n🇧🇷 Brasil (Português)\\\\n🇵🇹 Portugal (Português)\",\n            \"example_output\": {\n              \"messages\": [\n                \"Escolha sua região:\",\n                \"🇧🇷 Brasil (Português)\",\n                \"🇵🇹 Portugal (Português)\"\n              ]\n            }\n          }\n        }\n      },\n      {\n        \"rule_id\": 6,\n        \"category\": \"Context